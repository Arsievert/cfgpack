#!/bin/bash
#
# Pre-commit hook: format check, build + test.
# Installed by: ./scripts/setup.sh
#

# Resolve root directory (hook lives in .git/hooks/ via symlink to scripts/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# Handle both direct execution from scripts/ and symlink from .git/hooks/
if [ -f "$SCRIPT_DIR/run-tests.sh" ]; then
    ROOT_DIR="$(dirname "$SCRIPT_DIR")"
else
    ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
fi

# ── Stage 1: Format check ────────────────────────────────────────────────────
if ! make -C "$ROOT_DIR" format-check >/dev/null 2>&1; then
    printf "[pre-commit] FAIL: formatting -- run 'make format'\n"
    exit 1
fi

# ── Stage 2: Build and test ──────────────────────────────────────────────────
if ! make -C "$ROOT_DIR" tests >/dev/null 2>&1; then
    printf "[pre-commit] FAIL: build -- run 'make tests' for details\n"
    exit 1
fi

TEST_OUTPUT=$("$ROOT_DIR/scripts/run-tests.sh" 2>&1)
TEST_EXIT=$?
TEST_SUMMARY=$(echo "$TEST_OUTPUT" | sed 's/\x1b\[[0-9;]*m//g' | grep "^TOTAL:")

if [ $TEST_EXIT -ne 0 ]; then
    printf "[pre-commit] FAIL: %s\n" "$TEST_SUMMARY"
    exit 1
fi

printf "[pre-commit] OK: %s\n" "$TEST_SUMMARY"
